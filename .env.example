# =============================================================================
# Energie Teilen — environment variables
#
# Copy to `.env.local` for local development. In production, set the same
# variables in your Vercel project settings (Settings → Environment Variables)
# for the Production AND Preview environments.
#
# Convention:
#   REQUIRED  → must be set for the feature to work at all
#   OPTIONAL  → safe to omit (feature degrades gracefully)
#   PUBLIC    → exposed to the browser (anything prefixed `VITE_` is public)
# =============================================================================


# -----------------------------------------------------------------------------
# APP — base URLs and runtime
# -----------------------------------------------------------------------------

# REQUIRED. Public base URL of your deployed site. Used in Stripe success_url
# and cancel_url so users land back here after checkout.
# Examples:
#   local      → http://localhost:3000
#   preview    → https://energie-teilen-site-git-feature.vercel.app
#   production → https://energie-teilen-site.vercel.app  (or your custom domain)
APP_URL=http://localhost:3000

# OPTIONAL. Legacy alias — some earlier config used APP_BASE_URL.
# Server falls back to APP_URL if this is unset. Keep both during the migration.
APP_BASE_URL=

# OPTIONAL. Node port for the Express dev server (default 3001 to avoid
# conflicting with Vite on 3000). Used by `pnpm tsx server/index.ts`.
PORT=3001


# -----------------------------------------------------------------------------
# STRIPE — required for /api/pilot-checkout and the paid pilot flow
# -----------------------------------------------------------------------------

# REQUIRED. Server-side secret key. Test mode for now; rotate to live when ready.
#   Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# REQUIRED. Webhook signing secret. From Stripe dashboard → Developers → Webhooks.
# Point the webhook endpoint at: <APP_URL>/api/stripe/webhook
# Subscribe to event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# REQUIRED. Three Stripe Price IDs — one per pilot tier. Create them as
# one-time Products in your Stripe dashboard, then copy each `price_...` ID here.
STRIPE_PRICE_ET_ELIGIBILITY=price_...
STRIPE_PRICE_ET_STRUCTURING=price_...
STRIPE_PRICE_ET_MANDATE=price_...

# PUBLIC + OPTIONAL. Stripe publishable key, only needed if you ever embed
# Stripe Elements client-side. The Checkout redirect flow does NOT need it.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...


# -----------------------------------------------------------------------------
# RESEND — required for transactional email + lead notifications
# -----------------------------------------------------------------------------

# REQUIRED. Resend API key for sending lead notifications and confirmation
# emails. Sign up at https://resend.com, verify your domain, copy the key.
RESEND_API_KEY=re_...

# REQUIRED. Verified sender. Must match a domain you control in Resend.
# Format: "Display Name <email@your-domain.de>"
RESEND_FROM_EMAIL=Energie Teilen <noreply@energie-teilen.de>

# REQUIRED. Where lead and "paid pilot" notifications land in your inbox.
# Your inbox IS the database for v1 — that's why this matters.
LEAD_NOTIFICATION_EMAIL=vincenzo.grimaldi.engineering@gmail.com


# -----------------------------------------------------------------------------
# CLIENT-SIDE PUBLIC SIGNALS (anything VITE_-prefixed is exposed to the browser)
# -----------------------------------------------------------------------------

# OPTIONAL. Shows the "remaining pilot slots" banner in the hero. Number from
# 0..N. Omit or set to a negative number to hide the banner entirely.
VITE_PILOT_CAPACITY_REMAINING=

# OPTIONAL. Overrides the dev-server API target. Defaults to localhost:3001.
# Useful when developing against a deployed preview API.
VITE_DEV_API_TARGET=http://localhost:3001


# =============================================================================
# OPTIONAL / FUTURE
# Everything below is for features not yet wired into the live stack.
# Leave blank unless you have a concrete reason to use them.
# =============================================================================


# -----------------------------------------------------------------------------
# DURABLE KV (Upstash Redis) — ACTIVELY USED by server/index.ts
# Powers serverless-correct rate limiting + Stripe webhook idempotency +
# best-effort order/lead records. If unset, the server still runs but rate
# limiting falls back to per-instance memory (not reliable on Vercel).
# Create a free DB at https://console.upstash.com and paste the REST creds:
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# AWS — for future document uploads, DynamoDB persistence, SES email
# (an alternative to Resend if you migrate to AWS-native infra)
# -----------------------------------------------------------------------------
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB table for pilot application records (replaces Resend-only flow)
ET_PILOT_APPLICATIONS_TABLE=

# S3 bucket for client document uploads (Messkonzept, Lastgang exports, etc.)
ET_DOCUMENTS_BUCKET=

# Pre-signed upload URL lifetime in seconds
ET_UPLOAD_URL_TTL_SECONDS=900

# SES alternatives to RESEND_FROM_EMAIL / LEAD_NOTIFICATION_EMAIL
ET_FROM_EMAIL=
ET_INTERNAL_NOTIFICATION_EMAIL=


# -----------------------------------------------------------------------------
# ADMIN API — when you add the operator console
# -----------------------------------------------------------------------------

# Token required to access admin endpoints (e.g. lead list, manual refunds)
ADMIN_API_TOKEN=


# -----------------------------------------------------------------------------
# OBSERVABILITY — when you wire monitoring
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking (server + client)
SENTRY_DSN=

# Plausible analytics: the domain is set directly in client/index.html
# (data-domain="energie-teilen.de"). No env var needed. Register that exact
# domain in your Plausible account for events to be recorded.


# =============================================================================
# QUICK-START
# After filling Stripe + Resend + APP_URL, you can:
#   1. pnpm install
#   2. pnpm tsx server/index.ts         # in one terminal (Express :3001)
#   3. pnpm dev                          # in another terminal (Vite :3000)
#   4. Open http://localhost:3000
# Use Stripe test card 4242 4242 4242 4242 to complete a checkout.
# =============================================================================
